# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma / Postgres
# Use a URL-encoded password.
# For Supabase on IPv4 networks, prefer the Session pooler string on port 5432.
DATABASE_URL=
# Optional: dedicated Prisma CLI URL when runtime and migrations use different connections.
DIRECT_URL=

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# AI Runtime Config
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_MODEL_FAST=gpt-4o-mini
LLM_VISION_PROVIDER=openai
LLM_VISION_MODEL=gpt-4o
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536
MODERATION_PROVIDER=openai
MODERATION_MODEL=omni-moderation-latest
LLM_FALLBACK_PROVIDER=anthropic
LLM_FALLBACK_MODEL=claude-sonnet-4-5

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
